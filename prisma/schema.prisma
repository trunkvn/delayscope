// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActivityType {
  PROCRASTINATE
  FOCUS
}

model Log {
  id           String       @id @default(cuid())
  type         ActivityType
  score        Int
  tagId        String       // e.g., "tiktok_reels"
  level        Int          // 1, 2, or 3
  lat          Float        // Fuzzed coordinate
  lng          Float        // Fuzzed coordinate
  countryCode  String
  createdAt    DateTime     @default(now())

  @@index([countryCode])
  @@index([createdAt])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
}
